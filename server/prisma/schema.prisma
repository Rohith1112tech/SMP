datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEACHER
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id           String   @id @default(uuid())
  identifier   String   @unique // Email for Admin, Employee ID for Teacher, Mobile for Parent
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  teacherProfile Teacher?
  parentProfile  Parent?
}

model Teacher {
  id          String   @id @default(uuid())
  userId      String   @unique
  employeeId  String   @unique
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments TeacherAssignment[]
  marksGiven  Mark[]
}

model Parent {
  id           String    @id @default(uuid())
  userId       String    @unique
  parentMobile String    @unique // Matches the parentMobile criteria across students
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students     Student[] // Automatically links any student with this parentMobile
}

model Student {
  id           String   @id @default(uuid())
  name         String
  className    String   // e.g., "10-A", "11-B"
  parentMobile String   // Structural logical link to Parent profile
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  parent       Parent?  @relation(fields: [parentMobile], references: [parentMobile], onDelete: SetNull)
  attendance   Attendance[]
  marks        Mark[]

  @@index([className])
  @@index([parentMobile])
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  assignments TeacherAssignment[]
  marks       Mark[]
}

model TeacherAssignment {
  id        String   @id @default(uuid())
  teacherId String
  subjectId String
  className String   // e.g., "10-A"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // Prevents duplicate assignments of the same teacher to the same class/subject combo
  @@unique([teacherId, className, subjectId])
  @@index([className])
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  date      DateTime         @db.Date
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Ensures a student only has one explicit attendance record per calendar date
  @@unique([studentId, date])
  @@index([date])
}

model Mark {
  id            String   @id @default(uuid())
  studentId     String
  subjectId     String
  teacherId     String
  marksObtained Float
  totalMarks    Float    @default(100)
  examTerm      String   // e.g., "Midterm", "Finals"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  // Enforces single input per student per subject per exam term
  @@unique([studentId, subjectId, examTerm])
}
